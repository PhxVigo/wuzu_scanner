# Wuzu Scanner Configuration File - Example
# Copy this to config.toml and customize for your setup

[database]
# PostgreSQL connection settings
# You must set these to match your database setup
host = "localhost"          # Database server address
port = 5432                 # Default PostgreSQL port
database = "wuzu_game"      # Database name (must exist)
user = "wuzu_user"          # Database user (must have access)
password = "changeme"       # Database password

# To set up the database:
# 1. Create database: createdb wuzu_game
# 2. Create user: createuser wuzu_user -P
# 3. Grant access: psql -c "GRANT ALL PRIVILEGES ON DATABASE wuzu_game TO wuzu_user;"
# 4. Run schema: psql wuzu_game < schema.sql

[hardware]
# UHF RFID Reader settings
uhf_port = "COM9"           # Windows: "COM3", "COM9", etc.
                            # Linux: "/dev/ttyUSB0", "/dev/ttyUSB1", etc.
                            # Set to null for auto-detection (tries COM3 on Windows, /dev/ttyUSB0 on Linux)
                            
uhf_baudrate = 57600        # Serial baud rate - usually 57600 or 115200
                            # Check your reader's documentation
                            
uhf_power = 20              # RF Power in dBm (0-30)
                            # Higher = longer read range but more interference
                            # Start at 20 and adjust as needed

[timing]
# All timing values are in seconds

scan_timeout = 5            # Seconds of inactivity before ending a hunt
                            # After this many seconds with no new wuzus found,
                            # the scanning session ends

results_display = 10        # How long to show results screen before returning
                            # to main menu

scan_interval = 0.2         # Delay between UHF inventory scans
                            # Lower = more responsive but more CPU usage
                            # 0.2 seconds (200ms) is a good balance

nfc_poll_interval = 0.05    # Delay between NFC badge polls
                            # Lower = more responsive badge detection
                            # 0.05 seconds (50ms) works well

leaderboard_refresh = 60    # How often to refresh leaderboard from database
                            # In seconds. Set lower for more real-time updates
                            # but more database queries

[audio]
# Enable/disable all beeps
beep_enabled = true         # Set to false to disable all audio feedback

# Beep configurations use format: [active_time, silent_time, times]
# active_time: beep duration in 100ms units (1 = 100ms, 2 = 200ms, etc.)
# silent_time: pause between beeps in 100ms units
# times: number of times to repeat the beep pattern

[audio.beeps]
new_wuzu = [1, 0, 1]        # Quick single beep when wuzu is found
                            # [1, 0, 1] = 100ms beep, no pause, once

hunter_id = [2, 1, 2]       # Double beep when hunter scans badge
                            # [2, 1, 2] = 200ms beep, 100ms pause, twice

complete = [3, 2, 3]        # Triple beep pattern when scan completes
                            # [3, 2, 3] = 300ms beep, 200ms pause, three times

[display]
# Visual display settings

border_char = "─"           # Character used for box drawing borders
                            # "─" for clean lines, "=" for bold, "-" for ASCII

title = "WUZU SCANNER"      # Title text displayed in various screens
